{% extends 'base.html.twig' %}

{% block title %}{{ 'tag.index'|trans }}{% endblock %}

{% block body %}
    <h1>{{ 'tag.index'|trans }}</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nazwa</th>
                <th>Akcje</th>
            </tr>
        </thead>
        <tbody>
        {% for tag in tags %}
            <tr>
                <td>{{ tag.id }}</td>
                <td>{{ tag.name }}</td>
                <td>
<a href="{{ path('app_tag_show', {'id': tag.id}) }}" class="btn btn-primary btn-sm">
    Pokaż
</a>
<a href="{{ path('app_tag_edit', {'id': tag.id}) }}" class="btn btn-warning btn-sm">
    Edytuj
</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">brak tagów</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

<a href="{{ path('app_tag_new') }}" class="btn btn-success mb-3">
    {{ 'action.create_new'|trans }}
</a>
{% endblock %}
