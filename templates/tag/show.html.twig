{% extends 'base.html.twig' %}

{% block title %}Tag{% endblock %}

{% block body %}
    <h1>Tag</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ tag.id }}</td>
            </tr>
            <tr>
                <th>Nazwa</th>
                <td>{{ tag.name }}</td>
            </tr>
        </tbody>
    </table>

<a href="{{ path('app_tag_index') }}" class="btn btn-secondary mb-2">
    {{ 'action.back_to_list'|trans }}
</a>

<a href="{{ path('app_tag_edit', {'id': tag.id}) }}" class="btn btn-warning mb-2">
    Edytuj
</a>

    {{ include('tag/_delete_form.html.twig') }}
{% endblock %}
