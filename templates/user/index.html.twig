{% extends 'base.html.twig' %}

{% block title %}{{ 'user.index'|trans }}{% endblock %}

{% block body %}
    <h1>{{ 'user.index'|trans }}</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Email</th>
                <th>Role</th>
                <th>Akcje</th>
            </tr>
        </thead>
        <tbody>
        {% for user in users %}
            <tr>
                <td>{{ user.id }}</td>
                <td>{{ user.email }}</td>
                <td>{{ user.roles ? user.roles|json_encode : '' }}</td>
                <td>
<a href="{{ path('app_user_show', {'id': user.id}) }}" class="btn btn-primary btn-sm">
    Pokaż
</a>
                    <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="btn btn-warning btn-sm">
    Edytuj
</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">Brak użytkowników</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

<a href="{{ path('app_user_new') }}" class="btn btn-success mb-3">
    {{ 'action.create_new'|trans }}
</a>
{% endblock %}
