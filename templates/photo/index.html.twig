{% extends 'base.html.twig' %}

{% block title %}{{ 'photo.index'|trans }}{% endblock %}

{% block body %}
    <h1>{{ 'photo.index'|trans }}</h1>

    {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('app_photo_new') }}" class="btn btn-success mb-3">
            {{ 'action.create_new'|trans }}
        </a>
    {% endif %}

    <div class="row">
        {% for photo in photos %}
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <img
                        src="{{ asset('uploads/photos/' ~ photo.filename) }}"
                        class="card-img-top"
                        alt="{{ photo.title }}"
                        style="height: 250px; object-fit: cover;"
                    >

                    <div class="card-body">
                        <h2 class="card-title">{{ photo.title }}</h2>

                        <p class="card-text">
                            {{ photo.description }}
                        </p>

                        <p>
                            {% for tag in photo.tags %}
                                <a
                                    href="{{ path('app_photo_index', {'tag': tag.id}) }}"
                                    class="badge bg-secondary text-decoration-none"
                                >
                                    {{ tag.name }}
                                </a>
                            {% else %}
                                <span class="text-muted">
                                    {{ 'photo.no_tags'|trans }}
                                </span>
                            {% endfor %}
                        </p>

                        <a
                            href="{{ path('app_photo_show', {'id': photo.id}) }}"
                            class="btn btn-primary"
                        >
                            {{ 'photo.view_comments'|trans }}
                        </a>

                        {% if is_granted('ROLE_ADMIN') %}
                            <a
                                href="{{ path('app_photo_edit', {'id': photo.id}) }}"
                                class="btn btn-warning"
                            >
                                {{ 'action.edit'|trans }}
                            </a>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% else %}
            <p>{{ 'photo.no_photos'|trans }}</p>
        {% endfor %}
    </div>

    {% if totalPages > 1 %}
        <nav>
            <ul class="pagination">
                {% for page in 1..totalPages %}
                    <li class="page-item {% if page == currentPage %}active{% endif %}">
                        <a
                            class="page-link"
                            href="{{ path('app_photo_index', {
                                page: page,
                                tag: selectedTag
                            }) }}"
                        >
                            {{ page }}
                        </a>
                    </li>
                {% endfor %}
            </ul>
        </nav>
    {% endif %}

    {% if selectedTagEntity %}
        <div class="alert alert-info">
            {{ 'photo.filter_by_tag'|trans }}
            <strong>{{ selectedTagEntity.name }}</strong>

            <a
                href="{{ path('app_photo_index') }}"
                class="btn btn-sm btn-outline-primary ms-2"
            >
                {{ 'photo.show_all'|trans }}
            </a>
        </div>
    {% endif %}
{% endblock %}
