{% extends 'base.html.twig' %}

{% block title %}Photo{% endblock %}

{% block body %}
    <h1>Photo</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ photo.id }}</td>
            </tr>
            <tr>
                <th>Title</th>
                <td>{{ photo.title }}</td>
            </tr>
            <tr>
                <th>Filename</th>
                <td>{{ photo.filename }}</td>
<tr>
    <th>Obraz</th>
    <td>
        <img src="{{ asset('uploads/photos/' ~ photo.filename) }}" alt="{{ photo.title }}" style="max-width: 400px;">
    </td>
</tr>
            </tr>
<p>
    {{ photo.description }}
</p>
            <tr>
    <th>Tags</th>
    <td>
        {% for tag in photo.tags %}
            {{ tag.name }}{% if not loop.last %}, {% endif %}
        {% else %}
            brak
        {% endfor %}
    </td>
</tr>
        </tbody>
    </table>

    <a href="{{ path('app_photo_index') }}">back to list</a>

    {% if is_granted('ROLE_ADMIN') %}
    <a href="{{ path('app_photo_edit', {'id': photo.id}) }}">edit</a>
{% endif %}

    {% if is_granted('ROLE_ADMIN') %}
    {{ include('photo/_delete_form.html.twig') }}
{% endif %}

<hr>

<h2>Komentarze</h2>

{% if comments is empty %}
    <p>Brak komentarzy.</p>
{% else %}
    {% for comment in comments %}
        <div>
            <strong>{{ comment.nick }}</strong>
            <small>{{ comment.createdAt ? comment.createdAt|date('Y-m-d H:i') : '' }}</small>
            <p>{{ comment.content }}</p>
        </div>
        <hr>
    {% endfor %}
{% endif %}

{% if app.user %}
    {{ form_start(comment_form) }}
        {{ form_widget(comment_form) }}
        <button type="submit">Dodaj komentarz</button>
    {{ form_end(comment_form) }}
{% else %}
    <p>Aby dodać komentarz, <a href="{{ path('app_login') }}">zaloguj się</a>.</p>
{% endif %}

{% endblock %}
